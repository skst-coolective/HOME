<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SKST Collective</title>
  <style>
    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      font-family: Arial, Helvetica, sans-serif;
      background: #ffffff;
      color: #111111;
    }

    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 32px;
    }

    .wrap {
      width: 100%;
      max-width: 1100px;
      text-align: center;
    }

    h1 {
      margin: 0;
      font-size: clamp(44px, 9vw, 120px);
      line-height: 0.95;
      letter-spacing: 0.04em;
      font-weight: 800;
      text-transform: uppercase;
    }

    .subtitle {
      margin-top: 18px;
      font-size: clamp(16px, 2vw, 24px);
      color: #555555;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .email {
      display: inline-block;
      margin-top: 42px;
      font-size: clamp(18px, 2.2vw, 28px);
      color: #111111;
      text-decoration: none;
      border-bottom: 2px solid #111111;
      padding-bottom: 6px;
      transition: opacity 0.2s ease;
      word-break: break-word;
    }

    .email:hover {
      opacity: 0.65;
    }
  </style>
</head>
<body>
  <main class="wrap">
    <h1>SUBTEXTURA<br>VALENCIA 2026</h1>
    <div class="subtitle">SKST Collective</div>
    <a class="email" href="mailto:info@skst-collective.com">info@skst-collective.com</a>
  </main>
</body>
</html>
